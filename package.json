{
  "name": "medipanda-admin-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint --quiet --fix .",
    "preview": "vite preview",
    "generate-backend": "curl -sSL https://prod.api.medipanda.co.kr/api-docs >./api-docs.json && node ./generate-backend.cjs ./api-docs.json ./src/backend/backend.ts && eslint --fix ./src/backend/backend.ts; rm -f ./api-docs.json",
    "deploy:dev": "./deploy.sh --env dev",
    "deploy:prod": "./deploy.sh --env prod"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.2",
    "@mui/material": "^7.3.2",
    "@mui/x-charts": "^8.11.2",
    "@mui/x-date-pickers": "^8.11.2",
    "@tiptap/extension-document": "^3.4.3",
    "@tiptap/extension-file-handler": "^3.4.3",
    "@tiptap/extension-image": "^3.4.3",
    "@tiptap/extension-paragraph": "^3.4.3",
    "@tiptap/extension-text": "^3.4.3",
    "@tiptap/extensions": "^3.4.3",
    "@tiptap/pm": "^3.4.3",
    "@tiptap/react": "^3.4.3",
    "axios": "^1.12.2",
    "date-fns": "^4.1.0",
    "iconsax-reactjs": "^0.0.8",
    "lodash": "^4.17.21",
    "notistack": "^3.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.62.0",
    "react-router": "^6.30.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.5.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "sass-embedded": "^1.92.1",
    "type-fest": "^5.0.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vite-tsconfig-paths": "^5.1.4"
  }
